# Tangle-generated Python
from dataclasses import dataclass
from typing import Any, Optional

# Runtime helpers
class Result:
    def __init__(self, ok: bool, value: Any = None, error: str = ''):
        self.ok = ok
        self.value = value
        self.error = error

def Ok(value: Any = None) -> Result:
    return Result(True, value)

def Err(variant: str, value: Any = None) -> Result:
    return Result(False, value, variant)


def ApprovalFlow() -> Result:
    # group: Approval
    if (amount < 100):
        # group: Approval
        # style: highlight
        # action: auto_approve
        return Ok(None)
    # edge-style: stroke:#f00
    elif (amount < 1000):
        # action: manual_review
        return Ok(None)
    # skipped: crossed edge to reject

# Entry point
if __name__ == '__main__':
    result = ApprovalFlow()
    if not result.ok:
        print(f'Error: {result.error}', file=__import__('sys').stderr)
        exit(1)
    print(result.value)
