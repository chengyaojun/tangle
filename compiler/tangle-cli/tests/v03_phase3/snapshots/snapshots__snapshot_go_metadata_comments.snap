// Tangle-generated Go
package main

import (
    "fmt"
    "os"
)

type Result struct {
    Ok    bool
    Value interface{}
    Error string
}

func Ok(value interface{}) Result {
    return Result{Ok: true, Value: value}
}

func Err(variant string) Result {
    return Result{Ok: false, Error: variant}
}

func ApprovalFlow() Result {
    // group: Approval
    if amount < 100 {
        // group: Approval
        // style: highlight
        // action: auto_approve
        return Ok(nil)
    // edge-style: stroke:#f00
    } else if amount < 1000 {
        // action: manual_review
        return Ok(nil)
    }
    // skipped: crossed edge to reject
}

func main() {
    result := ApprovalFlow()
    if !result.Ok {
        fmt.Fprintf(os.Stderr, "Error: %s\n", result.Error)
        os.Exit(1)
    }
    fmt.Println(result.Value)
}
